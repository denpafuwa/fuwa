scene "Coffee Shop" {
    "You walk into a coffee shop."
    Barista: "Hello!"
    You: "Hi, a coffee please."
    Barista: "Nothing here. You need to go to the bar."
    choice "Go to bar" {
        set places_went 1
        goto "Bar"
    }
    choice "Don't go to bar" {
        You: "I'm okay here."
    }
    end
}
scene "Bar" {
    "You walk into a bar."
    Barkeep: "Hey there."
    You: "Hello..."
    You: "I need a drink..."
    end
}